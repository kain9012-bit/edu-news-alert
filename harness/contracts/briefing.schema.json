{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DailyEducationBriefing",
  "type": "object",
  "required": ["title", "executiveSummary", "keyTrends", "notableNews", "watchList"],
  "properties": {
    "title": { "type": "string" },
    "executiveSummary": { "type": "string" },
    "keyTrends": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "description", "evidenceIds"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "evidenceIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      }
    },
    "notableNews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["newsId", "reason"],
        "properties": {
          "newsId": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "watchList": { "type": "array", "items": { "type": "string" } }
  }
}
