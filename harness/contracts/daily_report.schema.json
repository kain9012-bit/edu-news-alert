{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InternalDailyEducationTrendReport",
  "type": "object",
  "required": ["metadata", "items", "ownOfficeItems", "omittedItems", "validation", "trace"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["reportId", "status", "windowStart", "windowEnd", "sourceCount", "publishedCount"]
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["newsId", "title", "summaryPoints", "analysisPoints", "applicationReviewPoints", "validation"]
      }
    },
    "omittedItems": {"type": "array"},
    "ownOfficeItems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["newsId", "title", "summaryPoints", "validation"],
        "properties": {
          "summaryPoints": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {"type": "string", "maxLength": 140}
          }
        }
      }
    },
    "validation": {"type": "object"},
    "trace": {"type": "array"}
  }
}