{
  "manifest_version": 3,
  "name": "교육청 보도자료 키워드 알리미",
  "description": "교육부와 시도교육청 보도자료에서 관심 키워드를 찾아 알려줍니다.",
  "version": "0.1.1",
  "minimum_chrome_version": "116",
  "permissions": ["alarms", "storage", "tabs", "sidePanel"],
  "host_permissions": ["https://kain9012-bit.github.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "보도자료 알리미 · 사이드바 열기"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "commands": {
    "open-news-alert": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "보도자료 알리미 사이드바 열기"
    }
  },
  "options_page": "options.html"
}
