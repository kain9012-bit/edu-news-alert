{
  "manifest_version": 3,
  "name": "교육동향 보도자료 알리미",
  "description": "교육부와 시도교육청의 최근 24시간 보도자료를 AI로 선별해 사이드바에서 확인합니다.",
  "version": "0.3.1",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "tabs", "sidePanel"],
  "host_permissions": ["https://kain9012-bit.github.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "교육동향 사이드바 열기"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "commands": {
    "open-news-alert": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "교육동향 사이드바 열기 또는 닫기"
    }
  },
  "options_page": "options.html"
}
